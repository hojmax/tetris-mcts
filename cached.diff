+    /// Get the board hash (256 bits for 200 cells)
+    #[inline]
+    pub fn get_board_hash(&self) -> [u64; 4] {
+        self.board_hash
+    }
+
+    /// Toggle a bit in the board hash for cell (x, y)
+    #[inline]
+    fn toggle_board_hash_bit(&mut self, x: usize, y: usize) {
+        let bit_index = y * self.width + x;
+        debug_assert!(bit_index < 200, "Board hash bit index out of bounds");
+        let u64_index = bit_index / 64;
+        let bit_offset = bit_index % 64;
+        self.board_hash[u64_index] ^= 1u64 << bit_offset;
+    }
+
+    /// Set a bit in the board hash for cell (x, y) to a specific value
+    #[inline]
+    pub(crate) fn set_board_hash_bit(&mut self, x: usize, y: usize, filled: bool) {
+        let bit_index = y * self.width + x;
+        debug_assert!(bit_index < 200, "Board hash bit index out of bounds");
+        let u64_index = bit_index / 64;
+        let bit_offset = bit_index % 64;
+        if filled {
+            self.board_hash[u64_index] |= 1u64 << bit_offset;
+        } else {
+            self.board_hash[u64_index] &= !(1u64 << bit_offset);
+        }
+    }
+
+    /// Recompute board hash from scratch (used in sync_board_stats)
+    pub(crate) fn recompute_board_hash(&mut self) {
+        self.board_hash = [0; 4];
+        for y in 0..self.height {
+            for x in 0..self.width {
+                if self.board[y][x] != 0 {
+                    self.set_board_hash_bit(x, y, true);
+                }
+            }
+        }
+    }
 }
